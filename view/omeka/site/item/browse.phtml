<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$this->inlineScript()->appendFile($this->assetUrl('js/minimasonry.min.js'));
$this->inlineScript()->appendFile($this->assetUrl('js/browse.js'));
if (isset($itemSet)) {
    // Item-set pages render their items as the same searchable ledger the
    // item pages use for linked resources (client title filter + AJAX paging).
    $this->inlineScript()->appendFile($this->assetUrl('js/linked-resources.js'));
}
$this->htmlElement('body')->appendAttribute('class', 'item resource browse');

$filterLocale = (bool) $this->siteSetting('filter_locale_values');
$lang = $this->lang();
$valueLang = $filterLocale ? [$lang, ''] : null;

$query = $this->params()->fromQuery();
$itemSetShow = isset($itemSet);
if ($itemSetShow) {
    $this->headLink()->appendStylesheet($this->assetUrl('css/resource-page-blocks.css', 'Omeka'));

    // Regions
    $mainBlockContent = $this->resourcePageBlocks($itemSet);
    $mainHasBlocks = $mainBlockContent->hasBlocks();
    $leftSidebarBlockContent = $this->resourcePageBlocks($itemSet, 'left');
    $leftSidebarHasBlocks = $leftSidebarBlockContent->hasBlocks();
    $rightSidebarBlockContent = $this->resourcePageBlocks($itemSet, 'right');
    $rightSidebarHasBlocks = $rightSidebarBlockContent->hasBlocks();

    $this->htmlElement('body')->appendAttribute('class', 'item-set');
    $query['item_set_id'] = $itemSet->id();
}

$layout = $this->browseLayout();
$isGrid = $layout['isGrid'];
$bodyTerm = $this->siteSetting('browse_body_property_term');
$bodyTruncate = $this->themeSetting('truncate_body_property');
?>

<?php if ($itemSetShow): ?>
    <?php echo $this->ResourceTags($itemSet); ?>
    <?php echo $this->pageTitle($itemSet->displayTitle(null, ($valueLang)), 1); ?>

    <?php if ($mainHasBlocks || $leftSidebarHasBlocks || $rightSidebarHasBlocks): ?>

        <?php
        $additionalContainerClasses = '';
        if ($mainHasBlocks && $leftSidebarHasBlocks && $rightSidebarHasBlocks) {
            $additionalContainerClasses = 'regions-container--all';
        }
        ?>

        <div class="regions-container <?php echo $additionalContainerClasses; ?>">
            <?php if ($leftSidebarHasBlocks && $blockContent = $leftSidebarBlockContent->getBlocks()): ?>
                <div class="sidebar-region sidebar-region--left">
                    <div class="metadata">
                        <?php echo $blockContent; ?>
                    </div>
                </div>
            <?php endif; ?>

            <?php if ($mainHasBlocks && $blockContent = $mainBlockContent->getBlocks()): ?>
                <div class="main-region">
                    <div class="metadata">
                        <?php echo $blockContent; ?>
                    </div>
                </div>
            <?php endif; ?>

            <?php if ($rightSidebarHasBlocks && $blockContent = $rightSidebarBlockContent->getBlocks()): ?>
                <div class="sidebar-region sidebar-region--right">
                    <div class="metadata">
                        <?php echo $blockContent; ?>
                    </div>
                </div>
            <?php endif; ?>
        </div>

    <?php endif; ?>

    <div class="item-set-items">
    <?php echo '<h2>' . $escape($translate('Items')) . '</h2>'; ?>
<?php else: ?>
    <?php echo $this->pageTitle($translate('Items'), 1); ?>
<?php endif; ?>

<?php echo $this->searchFilters(); ?>

<div class="browse-controls">
    <?php // The grid/list toggle has no meaning for the item-set ledger table. ?>
    <?php if (!$itemSetShow && $layout['hasToggle']): ?>
        <?php echo $this->partial('common/browse-toggle', [
            'gridState' => $layout['gridState'],
            'listState' => $layout['listState'],
        ]); ?>
    <?php endif; ?>
    <?php echo $this->browse()->renderSortSelector('items'); ?>
    <div class="advanced-search-container">
        <?php echo $this->hyperlink($translate('Advanced search'), $this->url('site/resource', ['controller' => 'item', 'action' => 'search'], ['query' => $query], true), ['class' => 'advanced-search']); ?>
    </div>
</div>

<?php $this->trigger('view.browse.before'); ?>

<?php if ($itemSetShow): ?>

    <?php
    // Ledger table mirroring the item pages' linked-resources section —
    // same classes (the linked-resources CSS applies as-is) and the same
    // .linked-resources root, so linked-resources.js provides the client
    // title filter and AJAX pagination here too. The id differs from the
    // linked-resources page block's so both can coexist on one page.
    $noResultsText = $translate('No resources match your search.');
    $resultsFoundText = $translate('{count} resources found');
    $rows = [];
    foreach ($items as $item) {
        $rows[] = ['resource' => $item, 'relationLabel' => null];
    }
    ?>
    <div id="item-set-resources"
         class="linked-resources"
         data-no-results-text="<?php echo $this->escapeHtmlAttr($noResultsText); ?>"
         data-results-found-text="<?php echo $this->escapeHtmlAttr($resultsFoundText); ?>">

        <div class="linked-resources__controls">
            <div class="linked-resources__search">
                <img src="<?php echo $this->assetUrl('img/search.svg'); ?>"
                     class="linked-resources__search-icon"
                     alt=""
                     aria-hidden="true">
                <input type="search"
                       id="item-set-resources-search"
                       name="item-set-resources-search"
                       class="linked-resources__search-input"
                       placeholder="<?php echo $this->escapeHtmlAttr($translate('Filter by title...')); ?>"
                       aria-label="<?php echo $this->escapeHtmlAttr($translate('Filter items by title')); ?>">
            </div>
        </div>

        <div class="linked-resources__status" role="status" aria-live="polite" aria-atomic="true"></div>

        <div class="linked-resources__no-results" hidden>
            <p><?php echo $escape($noResultsText); ?></p>
        </div>

        <?php echo $this->partial('common/linked-resources-table', [
            'rows' => $rows,
            'showRelation' => false,
            'valueLang' => $valueLang,
        ]); ?>

        <div class="linked-footer">
            <?php echo $this->pagination(); ?>
        </div>

    </div>

    </div><?php // close .item-set-items ?>
    <?php $this->trigger('view.browse.after'); ?>

<?php else: ?>

<ul class="resources <?php echo ($isGrid) ? 'resource-grid' : 'resource-list'; ?>">

    <?php foreach ($items as $index => $item): ?>
        <?php echo $this->partial('common/resource-card', [
            'resource' => $item,
            'isGrid' => $isGrid,
            'valueLang' => $valueLang,
            'liClass' => 'item',
            'decorationClass' => $layout['decorationClass'],
            'bodyTerm' => $bodyTerm,
            'bodyTruncate' => $bodyTruncate,
            'eager' => $index < 4,
        ]); ?>
    <?php endforeach; ?>

</ul>

<?php $this->trigger('view.browse.after'); ?>

<?php echo $this->pagination(); ?>

<?php endif; ?>
