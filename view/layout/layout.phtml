<?php
// XHR fast path for linked-resources pagination: the client sends
// X-Requested-With: fetch and only reads #linked-resources out of the
// response. Skip the entire layout (header, banner, footer, hex-to-HSL,
// assetUrl work) and output just the inner content.
if (($_SERVER['HTTP_X_REQUESTED_WITH'] ?? '') === 'fetch') {
    echo $this->content;
    return;
}

$siteTitle = $site->title();
$userBar = $this->userBar();
$header_layout = ($this->themeSetting('header_layout')) ?? 'inline';
$body_class = 'main-header--' . $header_layout;
$bannerHeightMobile = $this->themeSetting('banner_height_mobile');
$bannerEyebrow = $this->themeSetting('banner_eyebrow');
$bannerHeading = $this->themeSetting('banner_heading');
$bannerDescription = $this->themeSetting('banner_description');
$bannerHeightProperty = ($bannerEyebrow || $bannerHeading || $bannerDescription) ? 'min-height' : 'height';

// Brand color: SCSS derives every primary variant (--primary,
// --primary-hover, --primary-active, --focus-ring, glows, etc.) from
// --primary-base via color-mix(in oklab, ...). PHP only needs to inject
// the raw hex if the admin overrode the default. This replaces the
// previous HSL-conversion path which produced inconsistencies between
// the SCSS-tuned palette and the runtime values.
$primaryColor = $this->themeSetting('primary_color') ?? '#e64a19';
// Secondary seed: the shared 2nd categorical / data-series colour consumed by
// the IwacVisualizations module (chart series 2, compare-corpus B). SCSS
// derives --secondary (and its dark-mode lightening) from this base.
$secondaryColor = $this->themeSetting('secondary_color') ?? '#394f68';

// The hero banner only renders on the homepage (see below), so the LCP
// preload must be gated the same way — otherwise every inner page fetches
// a large unused image at high priority.
$layoutHomepage = method_exists($site, 'homepage') ? $site->homepage() : null;
$layoutIsHomepage = $layoutHomepage && $this->params()->fromRoute('page-slug') === $layoutHomepage->slug();

// For LCP: preload default banner image when no custom banner is set
$customBannerAsset = $this->themeSettingAsset('banner');
$defaultBannerUrl = $this->assetUrl('img/banner.webp');
// Responsive variants (regenerate with `npm run build:images`) so phones fetch a
// right-sized hero instead of the full 1400w master. Width-descriptor srcset;
// the <img> and the preload below both declare sizes=100vw (full-bleed banner).
$defaultBannerSrcset = $this->assetUrl('img/banner-480.webp') . ' 480w, '
    . $this->assetUrl('img/banner-768.webp') . ' 768w, '
    . $this->assetUrl('img/banner-1024.webp') . ' 1024w, '
    . $this->assetUrl('img/banner-1280.webp') . ' 1280w, '
    . $defaultBannerUrl . ' 1400w';

$this->htmlElement('html')->setAttribute('lang', $this->lang());
$this->headMeta()->setCharset('utf-8');
$this->headMeta()->appendName('viewport', 'width=device-width, initial-scale=1');
$this->headTitle($siteTitle)->setSeparator(' · ');
$this->headTitle()->append($this->setting('installation_title', 'Omeka S'));
$this->headLink()->prependStylesheet($this->assetUrl('css/style.css'));
// Omeka's Font Awesome (iconfonts.css) is loaded async (see <head> below) rather
// than render-blocking: the theme's own UI now draws from Bootstrap-Icon SVG
// masks, so the icon font is only needed by a few non-critical module glyphs.
$iconfontsUrl = $this->assetUrl('css/iconfonts.css', 'Omeka');
// Single combined Google Fonts request: Public Sans (body/UI) +
// Source Serif 4 with optical-size axis (display + body). Subsetted to
// the weights actually used across the theme.
// Bunny Fonts — privacy-first, GDPR-compliant drop-in mirror of Google
// Fonts. Relevant since IWAC is hosted at ZMO Berlin (German research
// institute), where Google Fonts has been ruled non-compliant under
// GDPR in some EU jurisdictions due to IP logging. Bunny does not log.
// IMPORTANT: Bunny's /css endpoint only honors the FIRST family in a
// CSS2-style multi-"&family=" request and silently drops the rest (verified
// live: "&family=" returned Public Sans only, 0 Source Serif faces). Use the
// v1 PIPE "|" separator BETWEEN families — that returns all faces including
// the source-serif-4 opsz axis. Do NOT revert to "&family=" or the display
// serif disappears and every heading falls back to Georgia.
// Besley (Clarendon) carries the masthead + headlines; three static faces
// keep the request small. Source Serif 4 stays for long-form reading.
$this->headLink()->prependStylesheet('https://fonts.bunny.net/css?family=besley:500,600,800|public-sans:ital,wght@0,400..700;1,400|source-serif-4:ital,opsz,wght@0,8..60,400..600;1,8..60,400&display=swap');
// jQuery + Omeka's global.js load render-blocking in the <head> ON PURPOSE.
// Omeka core and modules emit *inline* <script>s — the jsTranslate block,
// resource forms, etc. — that reference the `Omeka` global and `$` at parse
// time. Deferring these (tried in v2.6.14) leaves those globals undefined when
// the inline scripts run ("Omeka is not defined" on the homepage), so they must
// execute before parsing continues. The theme's OWN scripts are vanilla and stay
// deferred at the body end (see inlineScript below). The advanced-search
// item-sets inline jQuery was still rewritten in vanilla JS — a net win kept.
$this->headScript()->prependFile($this->assetUrl('js/global.js', 'Omeka'));
$this->headScript()->prependFile($this->assetUrl('vendor/jquery/jquery.min.js', 'Omeka'));
$this->jsTranslate();
$this->trigger('view.layout');

// The theme fully owns the language switcher: a custom template (inline SVG +
// text codes, no country flags) styled entirely from this theme's style.css.
// So the Internationalisation module's render-blocking flag-icon sprite AND its
// language-switcher.css (which styles the module's default markup we replaced)
// are dead weight on every page. Drop both from the <head>.
try {
    $headLinkContainer = $this->headLink()->getContainer();
    $deadCssKeys = [];
    foreach ($headLinkContainer as $key => $item) {
        if (!isset($item->href)) {
            continue;
        }
        $href = (string) $item->href;
        if (strpos($href, 'flag-icon') !== false
            || strpos($href, 'Internationalisation/asset/css/language-switcher') !== false
        ) {
            $deadCssKeys[] = $key;
        }
    }
    foreach ($deadCssKeys as $key) {
        unset($headLinkContainer[$key]);
    }
} catch (\Throwable $e) {
    // Non-fatal: if the placeholder shape changes upstream, keep the stylesheets.
}

if ($userBar) {
	$this->htmlElement('body')->appendAttribute('class', 'user-bar');
}
?>

<?php echo $this->doctype(); ?>
<?php echo $this->htmlElement('html'); ?>
	<head>
		<?php
		// Charset + viewport MUST come first. The banner preload below selects a
		// srcset candidate via imagesizes="100vw"; the preload scanner evaluates
		// that against the 980px *default* viewport unless <meta viewport> has
		// already been parsed — which would force the largest (1400w) image and
		// waste the high-priority fetch. Emitting headMeta first fixes the pick.
		echo $this->headMeta();
		?>
		<link rel="preconnect" href="https://fonts.bunny.net" crossorigin>
		<?php if (!$customBannerAsset && $layoutIsHomepage): ?>
		<link rel="preload" as="image" fetchpriority="high"
		      href="<?php echo $this->escapeHtmlAttr($defaultBannerUrl); ?>"
		      imagesrcset="<?php echo $this->escapeHtmlAttr($defaultBannerSrcset); ?>"
		      imagesizes="100vw">
		<?php endif; ?>
		<?php echo $this->headTitle(); ?>
		<?php echo $this->headLink(); ?>
		<?php echo $this->headStyle(); ?>
		<?php echo $this->headScript(); ?>

		<?php // Font Awesome (Omeka iconfonts.css) loaded async so the icon font never blocks first paint. ?>
		<link rel="preload" as="style" href="<?php echo $this->escapeHtmlAttr($iconfontsUrl); ?>" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="<?php echo $this->escapeHtmlAttr($iconfontsUrl); ?>"></noscript>

		<style type="text/css" media="screen">
			:root {
				/* Brand seeds; SCSS derives every primary/secondary variant via color-mix(in oklab, ...) */
				--primary-base: <?php echo $this->escapeHtml($primaryColor); ?>;
					--secondary-base: <?php echo $this->escapeHtml($secondaryColor); ?>;
				}
		</style>
		
		<?php if ($bannerHeightMobile && preg_match('/^-?[0-9]*\.?[0-9]+(px|em|rem|%|vh|vw|svh|dvh|lvh)$/', trim($bannerHeightMobile))): ?>
		<style type="text/css" media="screen and (max-width:768px)">
			.banner:not(.banner--compact) {
				<?php echo $this->escapeHtml($bannerHeightProperty) . ': ' . $this->escapeHtml(trim($bannerHeightMobile)) . ' !important;'; ?>
			}
		</style>
		<?php endif; ?>
	</head>

	<?php echo $this->htmlElement('body')->appendAttribute('class', $body_class); ?>
		<script>
		// Apply theme synchronously before first paint to prevent FOUC.
		// Mirrors getMode()/resolveTheme() in js/theme-toggle.js.
		(function () {
			try {
				var stored = localStorage.getItem('iwac-theme-preference');
				var theme = (stored === 'light' || stored === 'dark')
					? stored
					: (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.body.setAttribute('data-theme', theme);
				document.body.setAttribute('data-theme-mode', (stored === 'light' || stored === 'dark') ? stored : 'system');
			} catch (e) {}
		})();
		</script>
		<a id="skipnav" href="#content"><?php echo $this->translate('Skip to main content'); ?></a>

		<?php echo $this->partial('common/header', ['userBar' => $userBar, 'site' => $site]); ?>

		<?php
		// The full hero renders on the site homepage only; inner pages carry
		// a slim compact band of the same duotone plate so the page doesn't
		// open on bare whitespace between the section strip and the title.
		// Only the homepage hero is LCP-preloaded (see <head>); the compact
		// band asks for the image at low priority.
		echo $this->partial('common/banner', ['compact' => !$layoutIsHomepage, 'srcset' => $defaultBannerSrcset]);
		?>

		<div id="content" class="container" role="main" tabindex="-1">
			<?php echo $this->content; ?>
		</div>

		<?php echo $this->partial('common/footer'); ?>

		<button type="button" id="back-to-top" class="back-to-top" aria-label="<?php echo $this->escapeHtmlAttr($this->translate('Back to top')); ?>"></button>

		<?php
		echo $this->inlineScript()
			->prependFile($this->assetUrl('js/mirador-theme-sync.js'))
			->prependFile($this->assetUrl('js/pagination-scroll.js'))
			->prependFile($this->assetUrl('js/theme-toggle.js'))
			->prependFile($this->assetUrl('js/navigation.js'))
			->prependFile($this->assetUrl('js/script.js'))
			->prependFile($this->assetUrl('js/utils.js'));
		?>
	</body>
</html>
