<?php
$escapeAttr = $this->plugin('escapeHtmlAttr');
$closeText = $this->translate('Close');
?>
<?php // Translated strings for navigation.js travel as data-* attributes —
      // global consts would collide if any module declared the same name. ?>
<?php // Every other <nav> in the theme is labelled; without one this landmark
      // is announced as an anonymous "navigation" alongside the masthead and
      // section strips, which is exactly when a name matters most. ?>
<nav id="menu-drawer" class="menu-drawer" aria-hidden="true" inert style="display: none;"
	aria-label="<?php echo $escapeAttr($this->translate('Site menu')); ?>"
	data-close-text="<?php echo $escapeAttr($closeText); ?>"
	data-open-menu-text="<?php echo $escapeAttr($this->translate('Open menu')); ?>"
	data-toggle-submenu-text="<?php echo $escapeAttr($this->translate('Toggle submenu')); ?>"
	data-show-submenu-text="<?php echo $escapeAttr($this->translate('show submenu for “%s”')); ?>"
>
	<div class="wrap">

		<div class="navigation-controls">
			<button type="button"
				id="menu-backer"
				class="menu-backer is-empty"
				aria-hidden="true"
				tabindex="-1"
				title="<?php echo $escapeAttr($closeText); ?>"
			>
                <?php echo $this->escapeHtml($closeText); ?>
			</button>
		</div><!-- .navigation-controls -->

		<div id="menu-clones" class="menu-container">

			<?php
			// menus placed here via Javascript (see: asset/js/navigation.js)
			?>

		</div><!-- .menu-container -->

	</div><!-- .wrap -->
</nav><!-- menu-drawer -->
