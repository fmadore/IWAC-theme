<?php
/**
 * Theme override of Omeka core's common/search-form partial.
 *
 * Primary path — IwacSearch module active: this is the entry point to the
 * module's Typesense search. The form GETs to the module's faceted landing
 * page (/recherche on the French site, /search on the English one — resolved
 * by the iwacSearchUrl view helper), and the module's header bundle
 * progressively enhances it with a Typesense typeahead. The `name="q"` +
 * `data-iwac-header-search` hook are the contract the bundle looks for.
 * Without JS, the plain GET still lands on the faceted page, whose Svelte
 * client hydrates `?q=` straight from the URL.
 *
 * Fallback path — module absent: degrade to Omeka core's /index/search
 * fulltext form (param `fulltext_search`) so the theme keeps working
 * standalone. Markup mirrors core either way, so the existing #search-form /
 * .main-header__search-form CSS keeps applying.
 *
 * Placeholder uses 'Search' (reliably translated to "Rechercher" by Omeka
 * core on /s/afrique_ouest/) rather than core's 'Enter a search term', whose
 * msgid the French catalog doesn't supply.
 */
$translate  = $this->plugin('translate');
$escapeAttr = $this->plugin('escapeHtmlAttr');
$site       = $this->currentSite();

$useModule = $this->getHelperPluginManager()->has('iwacSearchUrl');
if ($useModule) {
    $action    = $this->iwacSearchUrl();
    $queryName = 'q';
    $query     = $this->params()->fromQuery('q');
} else {
    $action    = $site->url() . '/index/search';
    $queryName = 'fulltext_search';
    $query     = $this->params()->fromQuery('fulltext_search');
}
?>
<form action="<?php echo $escapeAttr($action); ?>" method="get"<?php echo $useModule ? ' data-iwac-header-search' : ''; ?> id="search-form" aria-label="<?php echo $escapeAttr($translate('Search')); ?>" role="search">
    <input type="text" id="fulltext-search" name="<?php echo $escapeAttr($queryName); ?>" value="<?php echo $escapeAttr($query); ?>" placeholder="<?php echo $escapeAttr($translate('Search')); ?>" aria-label="<?php echo $escapeAttr($translate('Query')); ?>" aria-labelledby="search-form fulltext-search">
    <button id="search-submit" type="submit" aria-label="<?php echo $escapeAttr($translate('Submit')); ?>" title="<?php echo $escapeAttr($translate('Submit')); ?>"><span class="o-icon-search" aria-hidden="true"></span></button>
</form>
