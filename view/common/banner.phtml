<?php
$escHtml = $this->plugin('escapeHtml');
$escAttr = $this->plugin('escapeHtmlAttr');
$translate = $this->plugin('translate');

$banner = $this->themeSettingAsset('banner');
$bannerWidth = $this->themeSetting('banner_width') ?? '';
$bannerHeight = $this->themeSetting('banner_height') ?? '';
$bannerVerticalPosition = ($this->themeSetting('banner_v_position')) ?? 'center';
$bannerHorizontalPosition = ($this->themeSetting('banner_h_position')) ?? 'center';

$bannerEyebrow = $this->themeSetting('banner_eyebrow');
$bannerHeading = $this->themeSetting('banner_heading');
$bannerDescription = $this->themeSetting('banner_description');
$bannerContentPosition = $this->themeSetting('banner_content_position') ?? 'left';

// Default banner image path (included with theme)
$defaultBannerUrl = $this->assetUrl('img/banner.webp');
// Width-descriptor srcset for the default hero, computed in layout.phtml so the
// LCP preload and this <img> stay in sync. Empty when a custom banner is used.
$bannerSrcset = isset($srcset) ? $srcset : '';
$hasCustomBanner = (bool) $banner;

$bannerHeightProperty = ($bannerEyebrow || $bannerHeading || $bannerDescription) ? 'min-height' : 'height';

// Inner (non-home) pages get a short image strip; only the homepage shows the
// full hero with the configurable height and overlay text.
$compact = !empty($compact);

$bannerInlineStyles = '';
$imageInlineStyles = '';

if (!$compact) {
    if ($bannerHeight) {
        $bannerInlineStyles .= "{$bannerHeightProperty}: {$bannerHeight};";
    } else {
        // Default hero stature: tall enough to carry the display heading,
        // capped so the fold still shows content underneath.
        $bannerInlineStyles .= "{$bannerHeightProperty}: clamp(20rem, 42vh, 32rem);";
    }
}

$imageInlineStyles .= "object-position: {$bannerHorizontalPosition} {$bannerVerticalPosition};";

$class = ['banner'];
$class[] = $bannerWidth;
if ($compact) {
    $class[] = 'banner--compact';
} elseif ($bannerEyebrow || $bannerHeading || $bannerDescription) {
    $class[] = 'has-text';
}
?>

<div class="<?php echo implode(' ', $class); ?>" style="<?php echo $escAttr($bannerInlineStyles); ?>">

    <?php
    // The homepage hero is the LCP candidate; the compact inner-page band is
    // decorative and must not compete with content fetches.
    $imageFetchPriority = $compact ? 'low' : 'high';
    ?>
    <?php
    // The image lives in its own clipping layer so the Ken Burns zoom is
    // contained WITHOUT the banner itself having to clip overflow — that
    // overflow:hidden was swallowing the IwacSearch typeahead panel the moment
    // it grew past the banner's bottom edge (the dropdown is appended inside
    // .banner__content, which sits outside this layer). See _banner.scss.
    ?>
    <div class="banner__media">
    <?php if ($hasCustomBanner): ?>
        <?php echo $this->thumbnail($banner, 'large', ['style' => $imageInlineStyles, 'role' => 'presentation', 'aria-hidden' => 'true', 'fetchpriority' => $imageFetchPriority]); ?>
    <?php else: ?>
        <img src="<?php echo $escAttr($defaultBannerUrl); ?>"
             <?php if ($bannerSrcset): ?>srcset="<?php echo $escAttr($bannerSrcset); ?>"
             sizes="100vw"
             <?php endif; ?>width="1400"
             height="787"
             style="<?php echo $escAttr($imageInlineStyles); ?>"
             role="presentation"
             aria-hidden="true"
             alt=""
             fetchpriority="<?php echo $escAttr($imageFetchPriority); ?>">
    <?php endif; ?>
    </div>

    <?php if (!$compact): ?>
    <?php
    // Homepage hero "almanac" figures — server-rendered collection counts
    // (design-review finding 1.2). Three indexed COUNT queries via the public
    // API replace the client-side ECharts overview for the four numbers, so
    // the proof of scale paints with the page and never shifts the layout.
    // The figures are disjoint categories: "Items" (FR "Contenus") sums only
    // the primary content classes — articles, periodical issues, audiovisual,
    // documents — so it excludes every authority/index record AND the
    // references, photographs and legacy items that a "total − index" count
    // would leave in. Index and References each count their own classes; the
    // six countries are a fixed editorial constant. Class IDs follow the IWAC
    // data model (see the iwac-data skill / docs/DESIGN-SYSTEM). Defensive: a
    // query failure just drops the strip, it never breaks the homepage.
    $stats = null;
    try {
        $statsApi = $this->api();
        $contentClasses = [36, 60, 38, 49];                       // articles, issues, audiovisual, documents
        $indexClasses   = [94, 9, 96, 54, 244];                   // persons, places, orgs, events, subjects
        $refClasses     = [35, 43, 88, 40, 82, 178, 52, 77, 305]; // the 9 reference classes
        $statsContent = $statsApi->search('items', ['resource_class_id' => $contentClasses, 'limit' => 0])->getTotalResults();
        $statsIndex   = $statsApi->search('items', ['resource_class_id' => $indexClasses,   'limit' => 0])->getTotalResults();
        $statsRefs    = $statsApi->search('items', ['resource_class_id' => $refClasses,     'limit' => 0])->getTotalResults();
        $stats = [
            ['n' => $statsContent, 'label' => $translate('Items'),      'featured' => true],
            ['n' => $statsIndex,   'label' => $translate('Index')],
            ['n' => $statsRefs,    'label' => $translate('References')],
            ['n' => 6,             'label' => $translate('Countries')],
        ];
    } catch (\Throwable $e) {
        $stats = null;
    }
    $thin = "\xE2\x80\xAF"; // U+202F narrow no-break space — locale-neutral digit grouping

    // Secondary "corpus in depth" tier — words, pages, sources, document types,
    // audiovisual minutes, languages. These are aggregates (sums of property
    // values), NOT cheap indexed COUNTs, so they can't be computed live the way
    // the four figures above are. They're read from IwacVisualizations'
    // precomputed snapshot — the very file its Collection Overview block renders
    // (generate_collection_overview.py, from the Hugging Face dataset). The read
    // is best-effort and read-only: if the module isn't installed or the file
    // is unreadable, this tier is simply omitted and the hero still shows the
    // four live counts. Figures are therefore as fresh as the last precompute
    // run, not live. OMEKA_PATH is the install root; modules are siblings of
    // themes/ under it.
    $substats = null;
    $overviewSnapshot = defined('OMEKA_PATH')
        ? OMEKA_PATH . '/modules/IwacVisualizations/asset/data/collection-overview.json'
        : null;
    if ($overviewSnapshot && is_readable($overviewSnapshot)) {
        try {
            $snap = json_decode((string) file_get_contents($overviewSnapshot), true);
            $sum = (is_array($snap) && !empty($snap['summary']) && is_array($snap['summary'])) ? $snap['summary'] : null;
            if ($sum) {
                $depthFields = [
                    ['key' => 'total_words',         'label' => $translate('Total words')],
                    ['key' => 'total_pages',         'label' => $translate('Total pages')],
                    ['key' => 'unique_sources',      'label' => $translate('Unique sources')],
                    ['key' => 'document_types',      'label' => $translate('Document types')],
                    ['key' => 'audiovisual_minutes', 'label' => $translate('Audiovisual minutes')],
                    ['key' => 'languages',           'label' => $translate('Languages')],
                ];
                $substats = [];
                foreach ($depthFields as $field) {
                    if (isset($sum[$field['key']]) && is_numeric($sum[$field['key']])) {
                        $substats[] = ['n' => $sum[$field['key']], 'label' => $field['label']];
                    }
                }
                if (!$substats) {
                    $substats = null;
                }
            }
        } catch (\Throwable $e) {
            $substats = null;
        }
    }
    ?>
    <div class="banner__content banner__content--<?php echo $bannerContentPosition; ?>">
        <?php if ($bannerEyebrow): ?>
            <span class="banner__eyebrow"><?php echo $escHtml($bannerEyebrow); ?></span>
        <?php endif; ?>
        <?php if ($bannerHeading): ?>
            <h1 class="banner__heading"><?php echo $escHtml($bannerHeading); ?></h1>
        <?php endif; ?>
        <?php if ($bannerDescription): ?>
            <p class="banner__description"><?php echo nl2br($escHtml($bannerDescription)); ?></p>
        <?php endif; ?>

        <?php // Hero search — the instrument, in the fold (finding 1.1). ?>
        <div class="banner__search">
            <?php echo $this->partial('common/search-form', ['variant' => 'hero']); ?>
        </div>

        <?php if ($stats): ?>
        <ul class="banner__stats" aria-label="<?php echo $escAttr($translate('Collection at a glance')); ?>">
            <?php foreach ($stats as $stat): ?>
                <li class="banner__stat<?php echo !empty($stat['featured']) ? ' banner__stat--featured' : ''; ?>">
                    <span class="banner__stat-figure"><?php echo $escHtml(number_format((int) $stat['n'], 0, '.', $thin)); ?></span>
                    <span class="banner__stat-label"><?php echo $escHtml($stat['label']); ?></span>
                </li>
            <?php endforeach; ?>
        </ul>
        <?php endif; ?>

        <?php if ($substats): ?>
        <ul class="banner__substats" aria-label="<?php echo $escAttr($translate('Corpus in depth')); ?>">
            <?php foreach ($substats as $stat): ?>
                <li class="banner__substat">
                    <span class="banner__substat-figure"><?php echo $escHtml(number_format((int) $stat['n'], 0, '.', $thin)); ?></span>
                    <span class="banner__substat-label"><?php echo $escHtml($stat['label']); ?></span>
                </li>
            <?php endforeach; ?>
        </ul>
        <?php endif; ?>
    </div>
    <?php endif; ?>
</div>
