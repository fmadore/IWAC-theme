<?php
$this->inlineScript()->appendFile($this->assetUrl('js/linked-resources.js'));

// Set up pagination. The helper preserves current query params automatically,
// so an active resource_property filter stays live across pages.
$pagination = $this->pagination(null, $totalCount, $page, $perPage);
$fragment = 'resources-linked';
$pagination->setFragment($fragment);

// Set up locale.
$valueLang = null;
if ($this->status()->isSiteRequest()) {
    $lang = $this->lang();
    $filterLocale = (bool) $this->siteSetting('filter_locale_values');
    $valueLang = $filterLocale ? [$lang, ''] : null;
}

$labelMap = [
    'items' => $this->translate('Items'),
    'item_sets' => $this->translate('Item sets'),
    'media' => $this->translate('Media'),
];

// Build facet chip data from the same source as the legacy <select>.
$facetChips = [];
foreach ($resourcePropertiesAll as $type => $resourceProperties) {
    if (!$resourceProperties) {
        continue;
    }
    foreach ($resourceProperties as $rp) {
        $label = $rp['label_is_translatable']
            ? $this->translate($rp['label'])
            : $rp['label'];
        $facetChips[] = [
            'compound_id' => $rp['compound_id'],
            'label' => $label,
            'type_label' => $labelMap[$type] ?? $type,
            'term' => $rp['term'],
        ];
    }
}

$baseUrl = $this->url(null, [], true);

$sortOptions = [
    'default' => $this->translate('Default'),
    'alpha-asc' => $this->translate('Title (A-Z)'),
    'alpha-desc' => $this->translate('Title (Z-A)'),
    'date-desc' => $this->translate('Newest first'),
    'date-asc' => $this->translate('Oldest first'),
];

$noResultsText = $this->translate('No resources match your search.');
$resultsFoundText = $this->translate('{count} resources found');

// Flatten the grouped subject values into the row shape the shared
// ledger-table partial expects.
$rows = [];
foreach ($subjectValues as $values) {
    $propertyLabel = $values[0]['property_alternate_label']
        ?? $this->translate($values[0]['property_label']);
    foreach ($values as $value) {
        $rows[] = [
            'resource' => $value['val']->resource(),
            'relationLabel' => $propertyLabel,
        ];
    }
}
?>
<div id="linked-resources"
     class="linked-resources"
     data-no-results-text="<?php echo $this->escapeHtmlAttr($noResultsText); ?>"
     data-results-found-text="<?php echo $this->escapeHtmlAttr($resultsFoundText); ?>"
     data-fragment="<?php echo $this->escapeHtmlAttr($fragment); ?>">

    <div class="linked-resources__controls">
        <div class="linked-resources__search">
            <img src="<?php echo $this->assetUrl('img/search.svg'); ?>"
                 class="linked-resources__search-icon"
                 alt=""
                 aria-hidden="true">
            <input type="search"
                   id="linked-resources-search"
                   name="linked-resources-search"
                   class="linked-resources__search-input"
                   placeholder="<?php echo $this->escapeHtmlAttr($this->translate('Filter by title...')); ?>"
                   aria-label="<?php echo $this->escapeHtmlAttr($this->translate('Filter linked resources by title')); ?>">
        </div>

        <div class="linked-resources__sort">
            <label for="linked-resources-sort" class="sr-only">
                <?php echo $this->translate('Sort by'); ?>
            </label>
            <select id="linked-resources-sort" class="linked-resources__sort-select">
                <?php foreach ($sortOptions as $value => $label): ?>
                    <option value="<?php echo $this->escapeHtmlAttr($value); ?>">
                        <?php echo $this->escapeHtml($label); ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>
    </div>

    <?php if ($facetChips): ?>
    <div class="linked-resources__facets"
         role="group"
         aria-label="<?php echo $this->escapeHtmlAttr($this->translate('Filter by relation')); ?>">
        <span class="linked-resources__facets-label">
            <?php echo $this->translate('Filter:'); ?>
        </span>
        <a href="<?php echo $this->escapeHtmlAttr($baseUrl . '#' . $fragment); ?>"
           class="linked-resources__facet<?php echo !$resourceProperty ? ' is-active' : ''; ?>"
           <?php echo !$resourceProperty ? 'aria-current="true"' : ''; ?>>
            <span class="linked-resources__facet-label"><?php echo $this->translate('All'); ?></span>
            <span class="linked-resources__facet-count"><?php echo $totalCount; ?></span>
        </a>
        <?php foreach ($facetChips as $chip): ?>
            <?php
            $isActive = $resourceProperty === $chip['compound_id'];
            $chipUrl = $baseUrl . '?' . http_build_query(['resource_property' => $chip['compound_id']]) . '#' . $fragment;
            ?>
            <a href="<?php echo $this->escapeHtmlAttr($chipUrl); ?>"
               class="linked-resources__facet<?php echo $isActive ? ' is-active' : ''; ?>"
               title="<?php echo $this->escapeHtmlAttr($chip['type_label'] . ' — ' . $chip['label']); ?>"
               <?php echo $isActive ? 'aria-current="true"' : ''; ?>>
                <span class="linked-resources__facet-label"><?php echo $this->escapeHtml($chip['label']); ?></span>
            </a>
        <?php endforeach; ?>
    </div>
    <?php endif; ?>

    <div class="linked-resources__status" role="status" aria-live="polite" aria-atomic="true"></div>

    <div class="linked-resources__no-results" hidden>
        <p><?php echo $this->escapeHtml($noResultsText); ?></p>
    </div>

    <?php echo $this->partial('common/linked-resources-table', [
        'rows' => $rows,
        'showRelation' => true,
        'valueLang' => $valueLang,
    ]); ?>

    <?php echo ($totalCount > $perPage) ? '<div class="linked-footer">' . $pagination . '</div>' : ''; ?>

</div>
