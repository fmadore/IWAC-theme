		<div class="main-header__tools">
			<div class="main-header__search-form">
				<?php echo $this->partial('common/search-form'); ?>
			</div>
			<div class="main-header__utilities">
				<?php // Language Switcher — requires the Internationalisation module.
				      // Guard the call: the module's languageSwitcher() helper resolves the
				      // current page's translations via $api->read('site_pages', …), which
				      // throws NotFoundException when the page is missing. On the 404 error
				      // page that throw fires *during* error rendering and escalates a clean
				      // 404 into a 500 (so crawlers never drop the dead URL). The switcher is
				      // non-essential chrome — swallow it and render nothing on routes that
				      // can't resolve a page; real pages are unaffected. ?>
				<?php if ($this->getHelperPluginManager()->has('languageSwitcher')): ?>
					<?php try { echo $this->languageSwitcher(); } catch (\Throwable $e) {} ?>
				<?php endif; ?>
				<?php // All three icons (system / light / dark) render; CSS selects one based on
				      // body[data-theme-mode]. The head-script in layout.phtml sets data-theme-mode
				      // before first paint, so the correct icon is shown synchronously
				      // and there's no flash-of-wrong-icon for users with prefers-color-scheme: dark. ?>
				<button class="theme-toggle" data-theme-toggle type="button"
					data-label-to-light="<?php echo $this->escapeHtmlAttr($translate('Switch to light mode')); ?>"
					data-label-to-dark="<?php echo $this->escapeHtmlAttr($translate('Switch to dark mode')); ?>"
					data-label-to-system="<?php echo $this->escapeHtmlAttr($translate('Switch to system theme')); ?>"
					aria-label="<?php echo $this->escapeHtmlAttr($translate('Switch to light mode')); ?>">
					<span class="theme-toggle__icon theme-toggle__icon--auto" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-circle-half" viewBox="0 0 16 16">
							<path d="M8 15A7 7 0 1 0 8 1zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16"/>
						</svg>
					</span>
					<span class="theme-toggle__icon theme-toggle__icon--light" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-brightness-high-fill" viewBox="0 0 16 16">
							<path d="M12 8a4 4 0 1 1-8 0 4 4 0 0 1 8 0M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
						</svg>
					</span>
					<span class="theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-moon-fill" viewBox="0 0 16 16">
							<path d="M6 .278a.77.77 0 0 1 .08.858 7.2 7.2 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277q.792-.001 1.533-.16a.79.79 0 0 1 .81.316.73.73 0 0 1-.031.893A8.35 8.35 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.75.75 0 0 1 6 .278"/>
