<?php
$translate = $this->plugin('translate');
$escape = $this->plugin('escapeHtml');
$decoration = $this->themeSetting('image_decoration');

if ($this->status()->isSiteRequest()) {
    $labelInfo = $this->siteSetting('property_label_information');
    $showLocale = (bool) $this->siteSetting('show_locale_label', true);
    $filterLocale = $this->siteSetting('filter_locale_values');
    $lang = $this->lang();
    $showValueAnnotations = (bool) $this->siteSetting('show_value_annotations', false);
} else {
    $labelInfo = $this->setting('property_label_information');
    $showLocale = true;
    $filterLocale = false;
    $lang = null;
    $showValueAnnotations = true;
}
$filterLocaleCallback = function ($value) use ($lang) {
    $valueLang = $value->lang();
    return $valueLang == '' || strcasecmp($valueLang, $lang) === 0;
};

// Properties whose values are produced by an AI pipeline (LLM summary,
// generated abstract, etc.) — get explicit provenance markup so readers
// can distinguish computational artefacts from human-authored metadata.
// Per the design principle of "computational honesty."
$aiGeneratedTerms = ['bibo:shortDescription'];
?>

<dl>
<?php
foreach ($values as $term => $propertyData):
    // dcterms:title is always rendered as the resource heading (the h1 on
    // show pages, the block heading in the item-with-metadata block, etc.),
    // so skip the duplicate "Title" metadata row.
    if ($term === 'dcterms:title') {
        continue;
    }
    $propertyValues = $propertyData['values'];
    if ($filterLocale) {
        $propertyValues = array_filter($propertyValues, $filterLocaleCallback);
    }
    if (!$propertyValues) {
        continue;
    }
    $property = $propertyData['property'];
    $propertyLabel = $propertyData['alternate_label'] ?: $translate($property->label());
    if ('term' === $labelInfo) {
        $propertyTerm = $property->term();
    } elseif ('vocab' === $labelInfo) {
        $propertyTerm = $property->vocabulary()->label();
    } else {
        $propertyTerm = null;
    }
    ?>
    <?php
    $isAiGenerated = in_array($term, $aiGeneratedTerms, true);
    // The "AI-generated" badge already signals provenance, so strip a trailing
    // "AI" from the label (e.g. "DescriptionAI" → "Description") to avoid the
    // doubled "AI … AI-generated" reading.
    $displayLabel = $isAiGenerated ? preg_replace('/\s*AI\s*$/i', '', $propertyLabel) : $propertyLabel;
    ?>
    <div class="property<?php echo $isAiGenerated ? ' property--ai' : ''; ?>" data-property-term="<?php echo $escape($term); ?>">
        <dt>
        <?php if ($isAiGenerated): ?>
            <span class="property__ai-mark" aria-hidden="true">&#x2726;</span>
        <?php endif; ?>
        <?php echo $escape($displayLabel); ?>
        <?php if ($isAiGenerated): ?>
            <span class="property__ai-badge" title="<?php echo $escape($translate('Generated by an AI model. Verify against the original source.')); ?>"><?php echo $escape($translate('AI-generated')); ?></span>
        <?php endif; ?>
        <?php if ($propertyTerm !== null) : ?>
        <span class="field-term">(<?php echo $escape($propertyTerm); ?>)</span>
        <?php endif; ?>
        </dt>
        <?php foreach ($propertyValues as $value): ?>
            <?php
            $valueType = $value->type();
            $valueLang = $value->lang();
            $valueAnnotation = $value->valueAnnotation();
            $class = ['value'];
            if ('resource' == $valueType || strpos($valueType, 'resource') !== false) {
                $class[] = 'resource';
                $class[] = $escape($value->valueResource()->resourceName());

                if ('media' == $value->valueResource()->resourceName() && is_array($decoration) && in_array('media', $decoration)) {
                    $class[] = 'decoration decoration--thumbnail';
                }
            } elseif ('uri' == $valueType) {
                $class[] = 'uri';
            }
            ?>
            <dd class="<?php echo implode(' ', $class); ?>" lang="<?php echo $escape($valueLang); ?>">
                <?php if ($showLocale && $valueLang) : ?>
                    <span class="language"><?php echo $escape($valueLang); ?></span>
                <?php endif; ?>
                <span class="value-content"><?php echo $filterLocale ? $value->asHtml($lang) : $value->asHtml(); ?></span>
                <?php if(!$value->isPublic()) : ?>
                    <span class="o-icon-private" role="img" title="<?php echo $this->escapeHtml($translate('Private')); ?>" aria-label="<?php echo $this->escapeHtml($translate('Private')); ?>"></span>
                <?php endif; ?>
                <?php if ($valueAnnotation && $showValueAnnotations) : ?>
                    <div class="annotation-btn">
                        <button type="button" class="annotation-trigger" aria-expanded="false" aria-label="<?php echo $this->escapeHtml($translate('Show annotation')); ?>">
                            <span class="o-icon-annotation" aria-hidden="true"></span>
                        </button>
                        <div class="annotation-tooltip" role="tooltip">
                            <div class="annotation-tooltip__wrapper">
                                <h6 class="annotation-tooltip__heading"><?php echo $this->escapeHtml($translate('Value Annotations')); ?></h6>
                                <?php echo $valueAnnotation->displayValues(); ?>
                            </div>
                        </div>
                    </div>
                <?php endif; ?>
                <?php $this->trigger('view.show.value', ['value' => $value]); ?>
            </dd>
        <?php endforeach; ?>
    </div>
<?php endforeach; ?>
</dl>
