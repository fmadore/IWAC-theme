<?php
/**
 * Grid/list layout toggle for browse-style listings.
 *
 * browse.js reads the data-view attribute to build the ?view= query
 * parameter — never derive it from the (translated) aria-label.
 *
 * Expected variables:
 * - $gridState / $listState: 'disabled' or '' (from the browseLayout helper)
 */
$translate = $this->plugin('translate');
$escapeAttr = $this->plugin('escapeHtmlAttr');
?>
<div class="layout-toggle">
    <button type="button" data-view="grid" aria-label="<?php echo $escapeAttr($translate('Grid')); ?>" title="<?php echo $escapeAttr($translate('Grid')); ?>" class="grid icon-btn o-icon-grid" <?php echo $gridState; ?>></button>
    <button type="button" data-view="list" aria-label="<?php echo $escapeAttr($translate('List')); ?>" title="<?php echo $escapeAttr($translate('List')); ?>" class="list icon-btn o-icon-list" <?php echo $listState; ?>></button>
</div>
